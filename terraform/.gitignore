# Local terraform directory (contains provider binaries and modules)
.terraform/

# .tfstate files (contain sensitive infrastructure data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files by default (often contain secrets)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc
